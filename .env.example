# Copy this file to .env for local development.
# Do not commit .env. Do not put real secrets in this example file.

# iFlytek Speech Recognition API
IFLYTEK_APP_ID=your_iflytek_app_id
IFLYTEK_API_KEY=your_iflytek_api_key
IFLYTEK_API_SECRET=your_iflytek_api_secret
IFLYTEK_API_URL=https://api.xf-yun.com/v1/private/sf8e6aca1
IFLYTEK_API_HOST=api.xf-yun.com

# ASR language for live interaction or evaluation.
# Examples: zh_cn, en_us
IFLYTEK_ASR_LANGUAGE=zh_cn
IFLYTEK_ASR_DOMAIN=iat
IFLYTEK_ASR_ACCENT=mandarin

# Evaluation targets
TARGET_TRANSCRIPTION_ACCURACY=0.93
TARGET_RESPONSE_TIME_MS=2000
